<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_chat_list_item"
    android:foreground="?attr/selectableItemBackground"
    android:padding="16dp">

    <FrameLayout
        android:id="@+id/itemChatAvatarFrame"
        android:layout_width="58dp"
        android:layout_height="58dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/itemChatAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_chat_avatar_partner"
            android:padding="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/female_profile_1" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="3dp"
            android:layout_marginBottom="3dp"
            android:background="@drawable/bg_chat_presence" />
    </FrameLayout>

    <TextView
        android:id="@+id/itemChatTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_time_pill"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="09:12"
        android:textColor="@color/chat_gold_soft"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/itemChatName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="12dp"
        android:text="Maja, 24"
        android:textColor="@color/text_primary"
        android:textSize="19sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/itemChatTime"
        app:layout_constraintStart_toEndOf="@id/itemChatAvatarFrame"
        app:layout_constraintTop_toTopOf="@id/itemChatAvatarFrame" />

    <TextView
        android:id="@+id/itemChatMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="10dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Jutro po 18:00 mam wolne, pasuje Ci?"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/itemChatAvatarFrame"
        app:layout_constraintEnd_toStartOf="@id/itemChatUnreadDot"
        app:layout_constraintStart_toEndOf="@id/itemChatAvatarFrame"
        app:layout_constraintTop_toBottomOf="@id/itemChatName" />

    <View
        android:id="@+id/itemChatUnreadDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_chat_unread_dot"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/itemChatMessage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/itemChatMessage" />

</androidx.constraintlayout.widget.ConstraintLayout>
