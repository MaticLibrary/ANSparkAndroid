<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end|bottom"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemMessageSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="Ty"
            android:textColor="@color/chat_meta_outgoing"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_bubble_outgoing"
            android:lineSpacingExtra="2dp"
            android:maxWidth="280dp"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Wiadomosc"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/itemMessageMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="09:12"
            android:textColor="@color/chat_meta_outgoing"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/itemMessageAvatar"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_chat_avatar_self"
        android:padding="3dp"
        android:scaleType="centerCrop"
        android:src="@drawable/male_profile" />

</LinearLayout>
